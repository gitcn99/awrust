# 配置示例
# 复制本文件为 config/config.toml 后按需填写真实连接信息。

# MySQL
[mysql.default]
host = "127.0.0.1"
port = 3306
user = "your_user"
password = "your_password"
database = "your_db"
# 最大连接数
# max_connections = 10
# SSL 模式：disabled / preferred / required
# ssl_mode = "preferred"
# 禁用 SQL 模式
# disable_sql_mode = false
# 连接超时时间（秒）
# acquire_timeout = 5
# 空闲连接断开时间（秒）
# idle_timeout = 60

# Redis
[redis.default]
url = "redis://:password@127.0.0.1:6379"

# Tracing 日志配置
[tracing]
level = "info"
format = "pretty"
